# ─── Contract addresses (fill after: forge script script/Deploy.s.sol) ─────────
NEXT_PUBLIC_MARKET_ADDRESS=0x...
NEXT_PUBLIC_USDC_ADDRESS=0x...
NEXT_PUBLIC_CHAIN_ID=11155111

# ─── RPC — free tier at alchemy.com or infura.io ──────────────────────────────
NEXT_PUBLIC_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ─── WalletConnect — free project at cloud.walletconnect.com ──────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# ─── Server-only: deployer private key (never exposed to browser) ─────────────
DEMO_ADMIN_PRIVATE_KEY=0x...
CONTRACT_DEPLOY_BLOCK=10697000
DATABASE_PATH=/data/app.db

# ─── Foundry deployment scripts (contracts/ only) ─────────────────────────────
PRIVATE_KEY=0x...
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
