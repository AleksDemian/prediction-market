# ─── Canonical addresses (shared by Docker/frontend/backend/contracts) ──────────
MARKET_ADDRESS=0x...
USDC_ADDRESS=0x...
CHAIN_ID=11155111

# ─── RPC — free tier at alchemy.com or infura.io ──────────────────────────────
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ─── WalletConnect — free project at cloud.walletconnect.com ──────────────────
WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# ─── Keys ───────────────────────────────────────────────────────────────────────
# Primary key used by contracts scripts.
PRIVATE_KEY=0x...
# Demo admin key is required for Resolve to execute automatically.
DEMO_ADMIN_PRIVATE_KEY=0x...

CONTRACT_DEPLOY_BLOCK=10696829
DATABASE_PATH=/data/app.db

# ─── Foundry deployment scripts (contracts/ only) ─────────────────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
# For contracts-only local workflow you can also copy contracts/.env.example.
